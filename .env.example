# Copy this file to .env and fill in your local values.
# Never commit your real .env with secrets.

# Claude (preferred — faster tool calling). If set, takes priority over Gemini.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Gemini fallback (used when ANTHROPIC_API_KEY is not set)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Sample library: either set SAMPLE_PROFILE, or set SAMPLE_DIR alone.
# SAMPLE_PROFILE=dev   → crawls SAMPLE_DIR_DEV or ./dev_samples (repo root)
# SAMPLE_PROFILE=all   → crawls SAMPLE_DIR_ALL or ./SAMPLES (repo root)
# (leave SAMPLE_PROFILE unset to use SAMPLE_DIR below)
# SAMPLE_PROFILE=dev
# SAMPLE_DIR_DEV=./dev_samples
# SAMPLE_DIR_ALL=./SAMPLES

SAMPLE_DIR=/Users/yourname/Music/Ableton/User Library

# Optional: MongoDB Atlas (Python backend — see backend/server/server/mongo/README.md)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
# MONGODB_DB_NAME=wonder

# Frontend (Next.js) + MCP — same file; optional (defaults match README)
# ABLETON_HOST=localhost
# ABLETON_PORT=9877
# PYTHON_API_URL=http://localhost:8000

# ElevenLabs — override where generated audio is saved
# (default: ~/Documents/Ableton/User Library/eleven_labs_audio)
# ELEVENLABS_OUTPUT_DIR=/Users/yourname/Documents/Ableton/User Library/eleven_labs_audio

# Tagging — Gemini models (optional; defaults match tagging.py)
GEMINI_VIBE_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# Must match your embedding model output size (gemini-embedding-001 default = 3072). LanceDB needs fixed width.
# GEMINI_EMBEDDING_DIM=3072
# Merge mode: save progress every N successful files (0 = off). Survives crashes before the final merge.
# TAG_CHECKPOINT_EVERY_N=25

# Optional overrides for tagging pipeline
TAG_DB_BACKEND=lancedb
TAG_DB_PATH=./data/sample_library.lance
TAG_DB_TABLE=samples
# merge = default: update rows for files indexed this run, keep other paths in the table
# overwrite = replace entire table with this run only
# append = add rows (may duplicate paths)
# TAG_DB_WRITE_MODE=merge
