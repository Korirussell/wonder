# =============================================================================
# Wonder Audio DAW — Backend Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# === ElevenLabs ===
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# === Google Gemini ===
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_AGENT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# === Sample Library (LanceDB) ===
SAMPLE_VECTOR_DIM=3072
TAG_DB_PATH=./data/sample_library.lance
TAG_DB_TABLE=samples
SAMPLE_DIR=./samples
GENERATED_SAMPLES_DIR=./generated_samples
SAMPLE_REUSE_THRESHOLD=0.72
SAMPLE_REUSE_MARGIN_THRESHOLD=0.05

# === Agent Feature Flags ===
USE_MODEL_INTENT_AGENT=false
USE_MODEL_RETRIEVAL_AGENT=false

# === MongoDB ===
MONGODB_URI=
MONGO_URI=
MONGO_DB=wonder
MONGODB_DB_NAME=wonder

# === Ableton ===
ABLETON_HOST=localhost
ABLETON_PORT=9877

# === Server ===
SERVER_OUTPUT_DIR=/tmp/wonder_server

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=

# === Snowflake (optional analytics) ===
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
